<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MertSY | Linkler</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    min-height:100vh;
    background:linear-gradient(135deg,#071120,#0d1b3d,#132b66);
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
}

.card{
    width:90%;
    max-width:400px;
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(20px);
    border:1px solid rgba(255,255,255,0.15);
    border-radius:28px;
    padding:35px;
    text-align:center;
    box-shadow:0 15px 40px rgba(0,0,0,0.35);
}

.avatar{
    width:110px;
    height:110px;
    border-radius:50%;
    background:linear-gradient(135deg,#ffffff,#8fb7ff);
    color:#0d1b3d;
    font-size:42px;
    font-weight:bold;
    display:flex;
    align-items:center;
    justify-content:center;
    margin:auto;
}

h1{
    margin-top:18px;
    font-size:30px;
}

.subtitle{
    color:#d7e5ff;
    margin-top:8px;
    margin-bottom:28px;
}

.link{
    display:flex;
    justify-content:center;
    align-items:center;
    gap:10px;

    text-decoration:none;
    color:white;

    background:rgba(255,255,255,0.1);
    border:1px solid rgba(255,255,255,0.15);

    padding:16px;
    border-radius:16px;

    margin-bottom:16px;

    transition:0.25s;
}

.link:hover{
    transform:translateY(-4px);
    background:white;
    color:#0d1b3d;
}

.footer{
    margin-top:25px;
    color:#b5c8ff;
    font-size:14px;
}
</style>
</head>

<body>

<div class="card">

<div class="avatar">M</div>

<h1>MertSY</h1>
<div class="subtitle">
Sosyal Medya Linklerim
</div>

<a class="link"
href="https://youtube.com/@mertsyae?si=amd8yGkXQpwdns_b"
target="_blank">
▶ YouTube
</a>

<a class="link"
href="https://t.me/aemertsy"
target="_blank">
✈ Telegram
</a>

<div class="footer">
Gece Mavisi • Beyaz Tema
</div>

</div>

<script>
document.querySelectorAll(".link").forEach(btn=>{
btn.addEventListener("click",()=>{
btn.style.transform="scale(0.96)";
setTimeout(()=>{
btn.style.transform="";
},120);
});
});
</script>

</body>
</html>